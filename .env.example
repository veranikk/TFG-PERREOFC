# ═══════════════════════════════════════════════════════════════
# PERREOFC — Copia este fichero como .env y rellena los valores
# ═══════════════════════════════════════════════════════════════

# ── Supabase (compartido por backend y scraper) ─────────────────
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=<tu-anon-key>
SUPABASE_SERVICE_KEY=<tu-service-key>

# ── Backend ─────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development
OWN_TEAM_ID=<id-de-tu-equipo-en-la-api>
GMAIL_USER=<tu-cuenta-gmail>
GMAIL_APP_PASSWORD=<tu-app-password-de-gmail>
N8N_WEBHOOK_URL=http://n8n:5678/webhook/perreito-chatbot

# ── Scraper ─────────────────────────────────────────────────────
SCRAPER_PORT=3001
INTERNAL_TOKEN=<token-aleatorio-largo>

# ── PostgreSQL (base de datos interna de n8n) ───────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=<contraseña-segura>
POSTGRES_DB=n8n

# ── n8n ─────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=<clave-aleatoria-32-chars>
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=<contraseña-panel-n8n>
GENERIC_TIMEZONE=Europe/Madrid
TZ=Europe/Madrid
N8N_PORT=5678

# ── Chat server (Fastify dentro de n8n-local) ───────────────────
CHAT_PORT=3002
N8N_CHAT_WEBHOOK_URL=http://n8n:5678/webhook/perreito-chatbot

# ── Frontend (Expo React Native) ────────────────────────────────
# IMPORTANTE: pon aquí la IP LAN de tu máquina (ejecuta ipconfig)
# El móvil necesita alcanzar el backend a través de la red local.
EXPO_PUBLIC_API_URL=http://<TU_IP_LAN>:3000/api/v1
LAN_IP=<TU_IP_LAN>
EXPO_TOKEN=<tu-expo-token>

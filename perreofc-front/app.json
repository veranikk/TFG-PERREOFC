{
  "_comment": "Expo app configuration for the Perreo FC frontend, including app identity, assets and native settings.",
  "expo": {
    "name": "Perreo FC",
    "slug": "perreofc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/icon.png",
    "scheme": "perreofc",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.perreofc.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#FDFFFF"
      },
      "package": "com.perreofc.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/brand/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/brand/icon.png",
          "color": "#FE6128",
          "sounds": []
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/BebasNeue-Regular.ttf",
            "./assets/fonts/Inter-Regular.ttf",
            "./assets/fonts/Inter-Medium.ttf",
            "./assets/fonts/Inter-SemiBold.ttf",
            "./assets/fonts/Inter-Bold.ttf"
          ]
        }
      ],
      "expo-splash-screen",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fb5b75a1-45a5-4c84-8675-e6762bb63c26"
      }
    },
    "owner": "veraa.mc"
  }
}

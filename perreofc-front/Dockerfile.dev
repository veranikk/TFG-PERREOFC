FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache bash git && \
    npm install -g @expo/ngrok@^4.0.0

COPY package.json package-lock.json ./
RUN npm ci

# Código fuente montado como volumen en runtime para hot reload

EXPOSE 19000
EXPOSE 19001
EXPOSE 8081

CMD ["npx", "expo", "start", "--tunnel"]

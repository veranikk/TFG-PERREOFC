{
  "_comment": "Backend package manifest: defines scripts, dependencies and module settings for running the API service.",
  "name": "perreo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "tsc && node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:types": "npx --yes supabase gen types typescript --project-id sbgqqnvgywxpemqhiaxa --schema public > src/shared/types/database.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@supabase/supabase-js": "^2.46.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "nodemailer": "^8.0.10",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}

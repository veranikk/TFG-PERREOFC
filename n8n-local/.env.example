# === PostgreSQL (interno de n8n) ===
POSTGRES_USER=n8n
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=n8n

# === n8n ===
# Clave de encriptación para credenciales que guardes en n8n.
# Genera una aleatoria larga (mínimo 32 caracteres) y NO la cambies después
# o perderás acceso a las credenciales ya guardadas.
N8N_ENCRYPTION_KEY=cambia_esto_por_algo_largo_y_aleatorio

# Usuario/contraseña para entrar al editor de n8n (http://localhost:5678)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambia_esta_password

# Zona horaria (importante para que los Schedule disparen a la hora correcta)
GENERIC_TIMEZONE=Europe/Madrid
TZ=Europe/Madrid

# Puerto local donde se accederá a n8n
N8N_PORT=5678
# Imagen oficial de Playwright para v1.49.1 — Ubuntu 24.04 Noble
# Incluye Chromium, Firefox, WebKit y todas sus dependencias de sistema
# NO usar alpine + playwright: combinación no soportada oficialmente
FROM mcr.microsoft.com/playwright:v1.59.1-noble

WORKDIR /app

RUN npm install -g pnpm@9.0.0

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# src/ se monta como volumen en runtime — no se copia aquí

EXPOSE 3001

CMD ["pnpm", "run", "dev"]
